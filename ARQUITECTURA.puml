@startuml API_Arquitectura
!theme plain

title API de Cursos - Arquitectura

package "Aplicación Flask" {
    [app.py] --> [extensions.py]
}

package "Controllers" {
    [CourseController.py]
    [CategoryController.py]
}

package "Services" {
    [courseService.py]
    [categoryService.py]
}

package "Repositories" {
    [courseRepository.py]
    [categoryRepository.py]
}

package "Models" {
    [Course Model]
    [Category Model]
}

database "MySQL Database" {
    table "courses" {
        int id
        string nombre
        text descripcion
        float precio
        int categoria_id
        datetime fecha_creacion
    }
    
    table "categories" {
        int id
        string name
        string description
        datetime created_at
    }
}

[app.py] --> [CourseController.py]
[app.py] --> [CategoryController.py]

[CourseController.py] --> [courseService.py]
[CategoryController.py] --> [categoryService.py]

[courseService.py] --> [courseRepository.py]
[categoryService.py] --> [categoryRepository.py]

[courseRepository.py] --> [Course Model]
[categoryRepository.py] --> [Category Model]

[Course Model] --> "courses"
[Category Model] --> "categories"

note right of [courseService.py]
  - Validaciones
  - Lógica de Negocio
  - Filtrados
end note

note right of [courseRepository.py]
  - CRUD Operations
  - Queries
  - Transacciones
end note

@enduml
